# Firebase Configuration
# Lấy từ Firebase Console -> Project Settings -> General

FIREBASE_API_KEY=YOUR_API_KEY_HERE
FIREBASE_AUTH_DOMAIN=rice-leaf-disease-classifier.firebaseapp.com
FIREBASE_PROJECT_ID=rice-leaf-disease-classifier
FIREBASE_STORAGE_BUCKET=rice-leaf-disease-classifier.appspot.com
FIREBASE_MESSAGING_SENDER_ID=902161620068
FIREBASE_APP_ID=YOUR_APP_ID_HERE
FIREBASE_DATABASE_URL=https://rice-leaf-disease-classifier.firebaseio.com

# Service Account (tải từ Firebase Console -> Project Settings -> Service Accounts)
# Lưu file JSON và để path ở đây
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account-key.json
